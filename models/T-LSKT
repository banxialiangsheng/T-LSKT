class FrequencyLayer(nn.Module):
    def __init__(self, dropout, hidden_size, n_heads_pre_attn=4, use_gated_fusion=True, n_concept=None, **kwargs):
        super(FrequencyLayer, self).__init__()
        self.out_dropout = nn.Dropout(dropout)
        self.LayerNorm = LayerNorm(hidden_size, eps=1e-12)
        self.use_gated_fusion = use_gated_fusion

        if n_concept is None:
            raise ValueError("n_concept must be provided for CC-EMA")
        self.n_concept = n_concept

        # 为每个知识点维护独立的长短期记忆状态
        self.concept_long_memory = nn.Parameter(torch.zeros(self.n_concept, hidden_size))
        self.concept_short_memory = nn.Parameter(torch.zeros(self.n_concept, hidden_size))

        self.concept_tau_embed = nn.Embedding(self.n_concept, 1)
       
        self.register_buffer('concept_initialized', torch.zeros(self.n_concept, dtype=torch.bool))

       
        self.pre_attn_layer_norm = LayerNorm(hidden_size, eps=1e-12)
        self.pre_attn = nn.MultiheadAttention(
            embed_dim=hidden_size,
            num_heads=n_heads_pre_attn,
            dropout=dropout,
            batch_first=True  
        )
        self.pre_dropout = nn.Dropout(dropout)

        if self.use_gated_fusion:
            self.gate_linear = nn.Linear(2 * hidden_size, hidden_size)
            nn.init.constant_(self.gate_linear.bias, 0.5)
            nn.init.xavier_uniform_(self.gate_linear.weight, gain=0.01)
        else:
            self.sqrt_beta = nn.Parameter(torch.ones(1, 1, hidden_size))

        self.alpha_proj = nn.Linear(hidden_size, 1)
        self.beta_proj = nn.Linear(hidden_size, 1)

        # Optimized: Initialize forgetting rates based on Ebbinghaus forgetting curve
        # softplus(-1.0) ≈ 0.31, softplus(-2.0) ≈ 0.13
        # Short-term memory decays faster (α > β)
        nn.init.constant_(self.alpha_proj.bias, -1.0)  
        nn.init.constant_(self.beta_proj.bias, -2.0) 
        nn.init.xavier_uniform_(self.alpha_proj.weight, gain=0.1) 
        nn.init.xavier_uniform_(self.beta_proj.weight, gain=0.1)

        self.tau_param = nn.Parameter(torch.tensor(0.05)) 
        self._ema_alpha_min = 0.01  # Optimized: increased from 1e-4 to allow faster updates
        self._ema_alpha_max = 0.999

    def forward(self, input_tensor, time_intervals=None, concept_ids=None, concept_embeds=None):
        batch, seq_len, hidden = input_tensor.shape

        if self.causal_attn:
            attn_mask = torch.triu(torch.ones(seq_len, seq_len) * float('-inf'), diagonal=1)
            attn_mask = attn_mask.to(input_tensor.device)
        else:
            attn_mask = None

        attn_output, attn_weights = self.pre_attn(
            query=input_tensor,
            key=input_tensor,
            value=input_tensor,
            attn_mask=attn_mask,
            need_weights=True,  
            average_attn_weights=True 
        )
       
        input_tensor = self.pre_attn_layer_norm(input_tensor + self.pre_dropout(attn_output))

       
        if concept_ids is not None:
            low_pass_list = []
            high_pass_list = []

            for t in range(seq_len):
                current_concepts = concept_ids[:, t]  # [batch]
                current_input = input_tensor[:, t, :]  # [batch, hidden]

                # 初始化当前时间步的输出
                batch_low_pass = torch.zeros_like(current_input)
                batch_high_pass = torch.zeros_like(current_input)

                for b in range(batch):
                    concept_id = current_concepts[b].item()
                    if concept_id < 0: 
                        batch_low_pass[b] = current_input[b]
                        batch_high_pass[b] = torch.zeros_like(current_input[b])
                        continue

        
                    tau_logit = self.concept_tau_embed(torch.tensor(concept_id, device=input_tensor.device))
                    tau_k = torch.clamp(F.softplus(tau_logit) + 1e-6, min=0.005, max=1.0) 

                    alpha_k = 1.0 - torch.exp(-torch.clamp(dt_k / tau_k, min=0.0, max=10.0))
                    alpha_k = alpha_k.clamp(min=self._ema_alpha_min, max=self._ema_alpha_max)

                    prev_long = self.concept_long_memory[concept_id]
                    new_long = (1.0 - alpha_k) * prev_long + alpha_k * current_input[b]
                    self.concept_long_memory[concept_id] = new_long

                    new_short = current_input[b] - new_long
                    self.concept_short_memory[concept_id] = new_short

                    
                    batch_low_pass[b] = new_long
                    batch_high_pass[b] = new_short

                low_pass_list.append(batch_low_pass)
                high_pass_list.append(batch_high_pass)

            # 转换为张量
            low_pass = torch.stack(low_pass_list, dim=1)  # [B, T, hidden]
            high_pass = torch.stack(high_pass_list, dim=1)  # [B, T, hidden]

        if time_intervals is not None:
           
            forget_alpha_per_step = F.softplus(self.alpha_proj(input_tensor)) 
            forget_beta_per_step = F.softplus(self.beta_proj(input_tensor)) 

            if concept_ids is not None:  
                dt_for_forget = time_intervals.unsqueeze(-1)  # [batch, seq_len, 1]
            else:
                dt_for_forget = dt_eff

            forget_factor_short = torch.exp(-forget_alpha_per_step * dt_for_forget)
            forget_factor_long = torch.exp(-forget_beta_per_step * dt_for_forget)

            low_pass = low_pass * forget_factor_long
            high_pass = high_pass * forget_factor_short

        if self.use_gated_fusion:
            gate_input = torch.cat([low_pass, high_pass], dim=-1)
            gate = torch.sigmoid(self.gate_linear(gate_input))  
            sequence_emb_fft = gate * low_pass + (1 - gate) * high_pass
        else:
            sequence_emb_fft = low_pass + (self.sqrt_beta ** 2) * high_pass
        hidden_states = self.out_dropout(sequence_emb_fft)
        hidden_states = self.LayerNorm(hidden_states + input_tensor)

        return hidden_states


class LayerNorm(nn.Module):
    """
    层归一化
    """

    def __init__(self, hidden_size, eps=1e-12):
        super(LayerNorm, self).__init__()
        self.weight = nn.Parameter(torch.ones(hidden_size))
        self.bias = nn.Parameter(torch.zeros(hidden_size))
        self.variance_epsilon = eps

    def forward(self, x):
        mean = x.mean(-1, keepdim=True)
        variance = ((x - mean) ** 2).mean(-1, keepdim=True)
        x = (x - mean) / torch.sqrt(variance + self.variance_epsilon)
        return self.weight * x + self.bias


class T-LSKT(nn.Module):

    def __init__(self, n_question, n_pid, d_model, n_blocks, dropout, d_ff=256, bar_d=128,
                 kq_same=1, final_fc_dim=512, num_attn_heads=8, separate_qa=False, l2=1e-5, seq_len=200, emb_type="qid",
                 emb_path="", pretrain_dim=768, num_buckets=32, max_distance=100, n_hat=0, max_local_shift=0.0,
                 d_state=64, d_conv=4, expand=1,
                 n_heads_pre_attn=4, n_concept=None, use_gated_fusion=True):
        super().__init__()
        
        self.model_name = "T-LSKT"
        self.n_question = n_question
        self.dropout = dropout
        self.kq_same = kq_same
        self.n_pid = n_pid
        self.l2 = l2
        self.model_type = self.model_name
        self.separate_qa = separate_qa
        self.emb_type = emb_type
        embed_l = d_model

        self.num_buckets = num_buckets
        self.max_distance = max_distance

        self.n_concept = n_concept

        if self.n_pid > 0:
            self.difficult_param = nn.Embedding(self.n_pid + 1, 1)  
            self.q_embed_diff = nn.Embedding(self.n_question + 1,
                                             embed_l) 
            self.qa_embed_diff = nn.Embedding(2 * self.n_question + 1, embed_l)  
        if emb_type.startswith("qid"):
            # n_question+1 ,d_model
            self.q_embed = nn.Embedding(self.n_question, embed_l)
            if self.separate_qa:
                self.qa_embed = nn.Embedding(2 * self.n_question + 1, embed_l)  # interaction emb
            else:  # false default
                self.qa_embed = nn.Embedding(2, embed_l)

        self.model = Framework(n_question=n_question, n_blocks=n_blocks, n_heads=num_attn_heads, dropout=dropout,
                               bar_d=bar_d,
                               d_model=d_model, d_feature=d_model / num_attn_heads, d_ff=d_ff, kq_same=self.kq_same,
                               model_type=self.model_type, seq_len=seq_len, emb_type=self.emb_type,
                               num_buckets=self.num_buckets, max_distance=self.max_distance, n_hat=n_hat,
                               max_local_shift=max_local_shift, d_state=d_state, d_conv=d_conv, expand=expand,
                               n_heads_pre_attn=n_heads_pre_attn, n_concept=n_concept,
                               use_gated_fusion=use_gated_fusion)

        self.out = nn.Sequential(
            nn.Linear(d_model + embed_l,
                      final_fc_dim), nn.ReLU(), nn.Dropout(self.dropout),
            nn.Linear(final_fc_dim, 256), nn.ReLU(
            ), nn.Dropout(self.dropout),
            nn.Linear(256, 1)
        )
        self.reset()

    def reset(self):
        for p in self.parameters():
            if p.dim() > 0 and p.size(0) == self.n_pid + 1 and self.n_pid > 0:
                torch.nn.init.constant_(p, 0.)

    def base_emb(self, q_data, target):
        q_embed_data = self.q_embed(q_data)  # BS, seqlen,  d_model# c_ct
        if self.separate_qa:
            qa_data = q_data + self.n_question * target
            qa_embed_data = self.qa_embed(qa_data)
        else:
            # BS, seqlen, d_model # c_ct+ g_rt =e_(ct,rt)
            qa_embed_data = self.qa_embed(target) + q_embed_data
        return q_embed_data, qa_embed_data

    def forward(self, q_data, target, pid_data=None, time_intervals=None, concept_ids=None, qtest=False):
        emb_type = self.emb_type
        # Batch First
        if emb_type.startswith("qid"):
            q_embed_data, qa_embed_data = self.base_emb(q_data, target)

        pid_embed_data = None
        if self.n_pid > 0:  # have problem id
            q_embed_diff_data = self.q_embed_diff(q_data) 
            pid_embed_data = self.difficult_param(pid_data) 
            q_embed_data = q_embed_data + pid_embed_data * \
                           q_embed_diff_data  # uq *d_ct + c_ct # question encoder

            qa_embed_diff_data = self.qa_embed_diff(
                target)  
            if self.separate_qa:
                qa_embed_data = qa_embed_data + pid_embed_data * \
                                qa_embed_diff_data  # uq* f_(ct,rt) + e_(ct,rt)
            else:
                qa_embed_data = qa_embed_data + pid_embed_data * \
                                (
                                            qa_embed_diff_data + q_embed_diff_data)  # + uq *(h_rt+d_ct) # （q-response emb diff + question emb diff）
            c_reg_loss = (pid_embed_data ** 2.).sum() * self.l2  # rasch部分loss
        else:
            c_reg_loss = 0.

        # BS.seqlen,d_model
        # Pass to the decoder
        # output shape BS,seqlen,d_model or d_model//2
        d_output = self.model(q_embed_data, qa_embed_data, pid_embed_data, time_intervals, concept_ids)

        concat_q = torch.cat([d_output, q_embed_data], dim=-1)
        output = self.out(concat_q).squeeze(-1)
        m = nn.Sigmoid()
        preds = m(output)
        if not qtest:
            return preds, c_reg_loss
        else:
            return preds, c_reg_loss, concat_q


class Framework(nn.Module):
    def __init__(self, n_question, n_blocks, d_model, d_feature,
                 d_ff, n_heads, dropout, bar_d, kq_same, model_type, seq_len, emb_type, num_buckets, max_distance,
                 n_hat, max_local_shift, d_state, d_conv=4, expand=1,
                 n_heads_pre_attn=4, n_concept=None, use_gated_fusion=True):
        super().__init__()
        """
            n_block : number of stacked blocks in the attention
            d_model : dimension of attention input/output
            d_feature : dimension of input in each of the multi-head attention part.
            n_head : number of heads. n_heads*d_feature = d_model
            n_heads_pre_attn : number of attention heads for pre-processing attention block
            max_concepts : maximum number of concepts in the dataset for concept-aware forgetting
        """
        self.d_model = d_model
        self.model_type = model_type
        self.num_buckets = num_buckets
        self.max_distance = max_distance
        self.emb_type = emb_type

        self.frequency_layer = FrequencyLayer(dropout, d_model, n_heads_pre_attn, use_gated_fusion, n_concept)

        if model_type in {'T-LSKT'}:
            self.blocks_1 = nn.ModuleList([
                TransformerLayer(d_model=d_model, d_feature=d_model // n_heads,
                                 d_ff=d_ff, dropout=dropout, n_heads=n_heads, kq_same=kq_same, emb_type=emb_type,
                                 num_buckets=self.num_buckets, max_distance=self.max_distance, bar_d=bar_d)
                for _ in range(n_blocks)
            ])
            self.blocks_2 = nn.ModuleList([
                TransformerLayer(d_model=d_model, d_feature=d_model // n_heads,
                                 d_ff=d_ff, dropout=dropout, n_heads=n_heads, kq_same=kq_same, emb_type=emb_type,
                                 num_buckets=self.num_buckets, max_distance=self.max_distance, bar_d=bar_d)
                for _ in range(n_blocks * 2)
            ])

class TransformerLayer(nn.Module):
    def __init__(self, d_model, d_feature,
                 d_ff, n_heads, dropout, kq_same, emb_type, num_buckets, max_distance, bar_d):
        super().__init__()
        """
            This is a Basic Block of Transformer paper. It containts one Multi-head attention object. Followed by layer norm and postion wise feedforward net and dropout layer.
        """
        self.num_buckets = num_buckets
        self.max_distance = max_distance
        kq_same = kq_same == 1
        # Multi-Head Attention Block
        self.masked_attn_head = MultiHeadAttention(
            d_model, d_feature, n_heads, dropout, kq_same=kq_same, emb_type=emb_type, num_buckets=self.num_buckets,
            max_distance=self.max_distance, bar_d=bar_d)

        # Two layer norm layer and two droput layer
        self.layer_norm1 = nn.LayerNorm(d_model)
        self.dropout1 = nn.Dropout(dropout)

        self.linear1 = nn.Linear(d_model, d_ff)
        self.activation = nn.ReLU()
        self.dropout = nn.Dropout(dropout)
        self.linear2 = nn.Linear(d_ff, d_model)

        self.layer_norm2 = nn.LayerNorm(d_model)
        self.dropout2 = nn.Dropout(dropout)

    def forward(self, mask, query, key, values, apply_pos=True, pdiff=None):
       
        seqlen, batch_size = query.size(1), query.size(0)
        nopeek_mask = np.triu(
            np.ones((1, 1, seqlen, seqlen)), k=mask).astype('uint8')
        src_mask = (torch.from_numpy(nopeek_mask) == 0).to(device)
        if mask == 0:  # If 0, zero-padding is needed.
            # Calls block.masked_attn_head.forward() method
            query2 = self.masked_attn_head(
                query, key, values, mask=src_mask, zero_pad=True,
                pdiff=pdiff)  
        else:
            # Calls block.masked_attn_head.forward() method
            query2 = self.masked_attn_head(
                query, key, values, mask=src_mask, zero_pad=False, pdiff=pdiff)

        query = query + self.dropout1((query2))  
        query = self.layer_norm1(query)  # layer norm
        if apply_pos:
            query2 = self.linear2(self.dropout(  
                self.activation(self.linear1(query))))
            query = query + self.dropout2((query2))  
            query = self.layer_norm2(query)
        return query


class MultiHeadAttention(nn.Module):
    def __init__(self, d_model, d_feature, n_heads, dropout, kq_same, num_buckets, max_distance, bar_d, bias=True,
                 emb_type="qid"):
        super().__init__()
        """
        It has projection layer for getting keys, queries and values. Followed by attention and a connected layer.
        """
        self.d_model = d_model
        self.d_k = d_feature
        self.emb_type = emb_type
        self.bar_d = bar_d
        
        if emb_type in ["qid_conv_kerple", "qid_conv_ker_noexp"]:
            self.kernel_bias = ParallelKerpleLog(n_heads)

        if emb_type.startswith("qid"):
            self.d_k = d_feature
            self.h = n_heads
            self.kq_same = kq_same

            self.v_linear = nn.Linear(d_model, d_model, bias=bias)
            self.k_linear = nn.Linear(d_model, d_model, bias=bias)
            if kq_same is False:
                self.q_linear = nn.Linear(d_model, d_model, bias=bias)
            self.dropout = nn.Dropout(dropout)
            self.proj_bias = bias
            self.out_proj = nn.Linear(d_model, d_model, bias=bias)
            self.gammas = nn.Parameter(torch.zeros(n_heads, 1, 1))
            torch.nn.init.xavier_uniform_(self.gammas)
            self._reset_parameters()

        def get_slopes(n):
            def get_slopes_power_of_2(n):
                start = (2 ** (-2 ** -(math.log2(n) - 3)))  # 2*(-(8 / n))
                ratio = start
                return [start * ratio ** i for i in range(n)]

            if math.log2(n).is_integer():
                return get_slopes_power_of_2(
                    n)  # In the paper, we only train models that have 2^a heads for some a. This function has
            else:  # some good properties that only occur when the input is a power of 2. To maintain that even
                closest_power_of_2 = 2 ** math.floor(
                    math.log2(n))  # when the number of heads is not a power of 2, we use this workaround.
                return get_slopes_power_of_2(closest_power_of_2) + get_slopes(2 * closest_power_of_2)[0::2][
                                                                   :n - closest_power_of_2]

        maxpos = 1000
        attn_heads = n_heads

        context_position = torch.arange(maxpos)[:, None].to(device)
        memory_position = torch.arange(maxpos)[None, :].to(device)
        relative_position = memory_position - context_position
        relative_position = torch.abs(relative_position).unsqueeze(0).expand(attn_heads, -1, -1)

        self.slopes = torch.Tensor(get_slopes(attn_heads)).to(device) * -1
        self.alibi = self.slopes.unsqueeze(1).unsqueeze(1) * relative_position
        self.alibi = self.alibi.view(1, attn_heads, maxpos, maxpos)

    def _reset_parameters(self):
        xavier_uniform_(self.k_linear.weight)
        xavier_uniform_(self.v_linear.weight)
        if self.kq_same is False:
            xavier_uniform_(self.q_linear.weight)

        if self.proj_bias:
            constant_(self.k_linear.bias, 0.)
            constant_(self.v_linear.bias, 0.)
            if self.kq_same is False:
                constant_(self.q_linear.bias, 0.)
            # constant_(self.attnlinear.bias, 0.)
            constant_(self.out_proj.bias, 0.)

    def forward(self, q, k, v, mask, zero_pad, pdiff=None):

        bs = q.size(0)

        if self.emb_type.startswith("qid"):
            # perform linear operation and split into h heads

            k = self.k_linear(k).view(bs, -1, self.h, self.d_k)
            if self.kq_same is False:
                q = self.q_linear(q).view(bs, -1, self.h, self.d_k)
            else:
                q = self.k_linear(q).view(bs, -1, self.h, self.d_k)
            v = self.v_linear(v).view(bs, -1, self.h, self.d_k)

            # transpose to get dimensions bs * h * sl * d_model

            k = k.transpose(1, 2)
            q = q.transpose(1, 2)
            v = v.transpose(1, 2)
            # calculate attention using function we will define next
            gammas = self.gammas
            if self.emb_type.find("pdiff") == -1:
                pdiff = None
            
            # 是否返回注意力权重
            return_attn = self.store_attention
            
            if self.emb_type in ["qid_conv_kerple", "qid_conv_ker_noexp"]:
                result = attention(q=q, k=k, v=v, d_k=self.d_k, mask=mask, dropout=self.dropout, zero_pad=zero_pad,
                                   gamma=gammas, pdiff=pdiff, alibi=self.alibi, emb_type=self.emb_type,
                                   bar_d=self.bar_d, kernel_bias=self.kernel_bias, return_attention_weights=return_attn)
            else:
                result = attention(q=q, k=k, v=v, d_k=self.d_k, mask=mask, dropout=self.dropout, zero_pad=zero_pad,
                                   gamma=gammas, pdiff=pdiff, alibi=self.alibi, emb_type=self.emb_type,
                                   bar_d=self.bar_d, return_attention_weights=return_attn)
            
            # 处理返回值
            if return_attn:
                scores, attn_weights = result
                # 平均多头注意力权重：[bs, heads, seqlen, seqlen] -> [bs, seqlen, seqlen]
                self.cached_attention_weights = attn_weights.mean(dim=1).detach()
            else:
                scores = result

            # concatenate heads and put through final linear layer
            concat = scores.transpose(1, 2).contiguous() \
                .view(bs, -1, self.d_model)

        output = self.out_proj(concat)

        return output

    def pad_zero(self, scores, bs, dim, zero_pad):
        if zero_pad:
            # # need: torch.Size([64, 1, 200]), scores: torch.Size([64, 200, 200]), v: torch.Size([64, 200, 32])
            pad_zero = torch.zeros(bs, 1, dim).to(device)
            scores = torch.cat([pad_zero, scores[:, 0:-1, :]], dim=1)
        return scores
